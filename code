<html lang='en'>
<head>
  <meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1'>
  <link href='https://fonts.googleapis.com/css2?family=Urbanist:wght@400;700&display=swap' rel='stylesheet'>
  <style>
    :root { --bg: #0a192f; --accent: #00f2ff; --card: #112240; --text: #e6f1ff; }
    body { font-family: 'Urbanist', sans-serif; background: var(--bg); color: var(--text); margin: 0; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .container { background: var(--card); padding: 40px; border-radius: 12px; box-shadow: 0 20px 50px rgba(0,0,0,0.5); width: 95%; max-width: 450px; text-align: center; border-top: 4px solid var(--accent); }
    h2 { font-size: 32px; font-weight: 700; margin-bottom: 5px; color: var(--accent); letter-spacing: 1px; }
    .status-box { background: rgba(0,242,255,0.05); padding: 15px; border-radius: 8px; margin-bottom: 25px; border: 1px solid rgba(0,242,255,0.1); }
