void moveServoSlow(int targetAngle) {
  int currentPos = myServo.read();
  int step = (targetAngle > currentPos) ? 1 : -1;
  while (currentPos != targetAngle) {
    currentPos += step;
    myServo.write(currentPos);
    delay(15);
  }
}

void sendEmail(String subject, String messageText) {
  SMTP_Message message;
  message.sender.name = "AEGIS";
  message.sender.email = AUTHOR_EMAIL;
  message.subject = subject;
  message.addRecipient("Admin", RECIPIENT_EMAIL);
  message.text.content = messageText;
  smtp.connect(&config);
  MailClient.sendMail(&smtp, &message);
}

void sendResponsePage(String icon, String title, String msg) {
  String page = getHeader();
  page += "<div class='icon-box'>" + icon + "</div>";
  page += "<h2>" + title + "</h2>";
  page += "<p>" + msg + "</p>";
  page += "<a href='/' class='btn-back'>Back to Home</a>";
  page += getFooter();
  server.send(200, "text/html", page);
}

void handleLogin() {
  if (server.arg("pass") == secretPassword) {
    if (!isUnlocked) {
      sendResponsePage("✅", "Unlocked!", "Access granted. System is opening , Coded by Shadow Hackers Team");
      digitalWrite(greenLed, HIGH);
      moveServoSlow(90);
      tone(buzzer, 1000, 500);
      isUnlocked = true;
      sendEmail("Alert", "System Unlocked Successfully , Coded by Shadow Hackers Team");
      delay(1000);
      digitalWrite(greenLed, LOW);
    } else {
      sendResponsePage("⚠️", "Already Unlocked", "The lock is currently open , Coded by Shadow Hackers Team");
    }
  } else {
    sendResponsePage("❌", "Access Denied", "Wrong password. Intruder alert sent , Coded by Shadow Hackers Team");
    digitalWrite(redLed, HIGH);
    tone(buzzer, 500, 300);
    sendEmail("Alert", "Failed Login Attempt! , Coded by Shadow Hackers Team");
    delay(1000);
    digitalWrite(redLed, LOW);
  }
}

void handleLock() {
  if (isUnlocked) {
    sendResponsePage("🔒", "Locked", "System has been secured , Coded by Shadow Hackers Team");
    moveServoSlow(0);
    isUnlocked = false;
    sendEmail("Alert", "System Locked");
  } else {
    sendResponsePage("⚠️", "Already Locked", "The system is already secure , Coded by Shadow Hackers Team");
  }
}

void setup() {
  Serial.begin(115200);
  pinMode(greenLed, OUTPUT); pinMode(redLed, OUTPUT); pinMode(buzzer, OUTPUT);
  ESP32PWM::allocateTimer(0);
  myServo.setPeriodHertz(50);
  myServo.attach(servoPin, 500, 2400);
  myServo.write(0);

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) { delay(500); Serial.print("."); }
  Serial.println("\nIP: "); Serial.println(WiFi.localIP());

  config.server.host_name = "smtp.gmail.com";
  config.server.port = 465;
  config.login.email = AUTHOR_EMAIL;
  config.login.password = AUTHOR_PASSWORD;

  server.on("/", []() { 
    String mainPage = getHeader() + String(htmlMainPage) + getFooter();
    server.send(200, "text/html", mainPage); 
  });
  server.on("/login", HTTP_POST, handleLogin);
  server.on("/lock", HTTP_POST, handleLock);
  server.begin();
}

void loop() { server.handleClient(); }
