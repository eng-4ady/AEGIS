void sendEmail(String subject, String messageText) {
  SMTP_Message message;
  message.sender.name = "AEGIS SECURITY";
  message.sender.email = AUTHOR_EMAIL;
  message.subject = subject;
  message.addRecipient("Admin", RECIPIENT_EMAIL);
  message.text.content = messageText + "\n\nCoded by Shadow Hackers Team";
  if (smtp.connect(&config)) MailClient.sendMail(&smtp, &message);
}

// دالة الإنذار (ترددات أعلى بكتير لصوت أوضح)
void triggerPanicAlarm() {
  for (int i = 0; i < 15; i++) {
    tone(buzzer, 5000); digitalWrite(redLed, HIGH); delay(70);
    tone(buzzer, 6000); digitalWrite(redLed, LOW); delay(70);
  }
  noTone(buzzer);
}

void handleLogin() {
  if (server.arg("pass") == secretPassword) {
    server.send(200, "text/html", getHeader() + "<h2>SUCCESS</h2><p>Access Granted</p><a href='/' class='btn-back'>Back to Home</a></div></body></html>");
    digitalWrite(greenLed, HIGH); 
    tone(buzzer, 3000, 300); // نغمة فتح حادة
    myServo.write(90);
    isUnlocked = true;
    sendEmail("ALERT", "System Unlocked.");
    delay(1500); digitalWrite(greenLed, LOW);
  } else {
    server.send(200, "text/html", getHeader() + "<h2 style='color:#ef4444;'>DENIED</h2><p>Intruder Detected</p><a href='/' class='btn-back'>Try Again</a></div></body></html>");
    triggerPanicAlarm();
    sendEmail("BREACH", "Wrong Password!");
  }
}

void handleLock() {
  server.send(200, "text/html", getHeader() + "<h2>SECURED</h2><p>System Locked</p><a href='/' class='btn-back'>Back to Dashboard</a></div></body></html>");
  myServo.write(0);
  isUnlocked = false;
  // صوت قفل قوي
  for(int i=0; i<3; i++) { tone(buzzer, 4000, 150); delay(200); }
  sendEmail("NOTICE", "System Secured.");
}

void handleAdminInfo() {
  String p = getHeader();
  p += "<h2>SECURITY INFO</h2>";
  p += "<div class='status-box'><p>To update keys, contact Admin at:</p>";
  p += "<p style='color:var(--accent); font-size:18px;'><b>shadynoreldin512@gmail.com</b></p></div>";
  p += "<a href='/' class='btn-back'>Back to Dashboard</a>"; // زرار الرجوع الواضح
  p += "</div></body></html>";
  server.send(200, "text/html", p);
}

void setup() {
  pinMode(greenLed, OUTPUT); pinMode(redLed, OUTPUT); pinMode(buzzer, OUTPUT);
  myServo.attach(servoPin); myServo.write(0);
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) delay(500);

  config.server.host_name = "smtp.gmail.com";
  config.server.port = 465;
  config.login.email = AUTHOR_EMAIL;
  config.login.password = AUTHOR_PASSWORD;

  server.on("/", []() {
    String p = getHeader();
    p += "<h2>AEGIS OS</h2>";
    p += "<div class='status-box'>Status: <b>" + String(isUnlocked ? "OPEN" : "LOCKED") + "</b></div>";
    p += "<form action='/login' method='POST'><input type='password' name='pass' placeholder='Password' required><button class='btn-unlock'>Unlock</button></form>";
    p += "<form action='/lock' method='POST'><button class='btn-lock'>Lock</button></form>";
    p += "<div class='admin-footer'><a href='/admin-info' style='color:#64748b; text-decoration:none;'>Change Password?</a></div>";
    p += "</div></body></html>";
    server.send(200, "text/html", p);
  });

  server.on("/login", HTTP_POST, handleLogin);
  server.on("/lock", HTTP_POST, handleLock);
  server.on("/admin-info", handleAdminInfo);
  server.begin();
}

void loop() { server.handleClient(); }
